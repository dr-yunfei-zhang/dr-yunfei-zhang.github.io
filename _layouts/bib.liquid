---
---

<div class="row">
  <div class="col-sm-2 abbr">
    {% if entry.abbr %}
      {% if entry.abbr == "Book" %}
        <abbr class="badge">{{ entry.abbr }}</abbr>
      {% elsif entry.abbr == "Patent" %}
        <abbr class="badge">{{ entry.abbr }}</abbr>
      {% else %}
        <abbr class="badge">{{ entry.abbr }}</abbr>
      {% endif %}
    {% endif %}
  </div>

  <div id="{{ entry.key }}" class="col-sm-8">
    
    <!-- Title -->
    <div class="title">{{ entry.title }}</div>

    <!-- Author -->
    <div class="author">
      {% assign author_array_size = entry.author_array | size %}
      {% assign author_array_limit = site.max_author_limit %}

      {% if author_array_limit and author_array_size > author_array_limit %}
        {% assign authors = entry.author_array | slice: 0, author_array_limit %}
      {% else %}
        {% assign authors = entry.author_array %}
      {% endif %}

      {% for author in authors %}
        {% assign author_last = author.last | downcase %}
        {% assign author_first = author.first | downcase %}

        {% if author_last == site.scholar.last_name[0] | downcase %}
          <strong>{{ author.first }} {{ author.last }}</strong>
        {% else %}
          {{ author.first }} {{ author.last }}
        {% endif %}

        {% unless forloop.last %}
          and
        {% endunless %}
      {% endfor %}

      {% if author_array_limit and author_array_size > author_array_limit %}
        <span class="more-authors" style="display: none;">
          {% for author in entry.author_array offset:author_array_limit %}
            and {{ author.first }} {{ author.last }}
          {% endfor %}
        </span>
        <span class="show-more-authors">... <em>show more</em></span>
      {% endif %}
    </div>

    <!-- ✅ 新增：完整期刊/会议名称（重点） -->
    {% if entry.journal %}
      <div class="publication-venue">
        <em>{{ entry.journal }}</em>
      </div>
    {% elsif entry.booktitle %}
      <div class="publication-venue">
        <em>{{ entry.booktitle }}</em>
      </div>
    {% endif %}

    <!-- Journal/Book title and date -->
    {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
    {% assign thesis = 'thesis,phdthesis,mastersthesis' | split: ',' %}

    {% if entry.journal %}
      {% capture entrytype %}<em>{{ entry.journal }}</em>{% endcapture %}
    {% elsif proceedings contains entry.type %}
      {% capture entrytype %}<em>In {{ entry.booktitle }}</em>{% endcapture %}
    {% elsif thesis contains entry.type %}
      {% capture entrytype %}<em>{{ entry.school }}</em>{% endcapture %}
    {% else %}
      {% capture entrytype %}{% endcapture %}
    {% endif %}

    {% capture entryyear %}{{ entry.year }}{% endcapture %}
    {% capture entrymonth %}{{ entry.month | capitalize }}{% endcapture %}

    {% capture periodical %}
      {{ entrymonth }} {{ entryyear }}
    {% endcapture %}

    <div class="periodical">
      {{ periodical | strip }}
    </div>

    <!-- Links/Buttons -->
    <div class="links">
      {% if entry.abstract %}
        <a class="abstract btn btn-sm z-depth-0" role="button">ABS</a>
      {% endif %}
      {% if entry.doi %}
        <a href="https://doi.org/{{ entry.doi }}" class="btn btn-sm z-depth-0" role="button">DOI</a>
      {% endif %}
      {% if entry.html %}
        <a href="{{ entry.html }}" class="btn btn-sm z-depth-0" role="button">HTML</a>
      {% endif %}
      {% if entry.pdf %}
        <a href="{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">PDF</a>
      {% endif %}
      {% if entry.code %}
        <a href="{{ entry.code }}" class="btn btn-sm z-depth-0" role="button">Code</a>
      {% endif %}
      {% if entry.video %}
        <a href="{{ entry.video }}" class="btn btn-sm z-depth-0" role="button">Video</a>
      {% endif %}
    </div>

  </div>
</div>